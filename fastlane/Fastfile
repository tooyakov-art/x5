require "base64"
require "json"

default_platform(:ios)

APP_BUNDLE_ID = "com.x5studio.app"
KEY_PATH = File.expand_path("asc_api_key.json", __dir__)

platform :ios do
  before_all do
    setup_api_key
  end

  # Editable version target. fastlane requires this when no editable
  # AppStoreVersion exists in ASC yet — otherwise it loops on
  # "Cannot find edit app store version" and times out (build 43 ASC
  # upload run hit this).
  APP_VERSION = "1.1.0"

  desc "Push metadata + screenshots, do NOT submit"
  lane :upload do
    deliver(
      api_key_path: KEY_PATH,
      app_identifier: APP_BUNDLE_ID,
      app_version: APP_VERSION,
      platform: "ios",
      skip_metadata: false,
      skip_screenshots: false,
      skip_binary_upload: true,
      submit_for_review: false,
      automatic_release: false,
      run_precheck_before_submit: false,
      overwrite_screenshots: true,
      force: true
    )
  end

  # ASC has an old `1.0` version stuck in PENDING_DEVELOPER_RELEASE
  # (the caption-studio era approval). It blocks creating 1.1.0 with
  # 'You cannot create a new version of the App in the current state'.
  # This lane uses Spaceship's developer-reject (the API action exposed
  # in the UI as "Reject This Version") to free the slot. After this
  # runs successfully, `lane :upload` can create 1.1.0 fresh.
  desc "Developer-reject the currently-pending version so a new one can be created"
  lane :reject_pending do
    deliver(
      api_key_path: KEY_PATH,
      app_identifier: APP_BUNDLE_ID,
      platform: "ios",
      reject_if_possible: true,
      skip_metadata: true,
      skip_screenshots: true,
      skip_binary_upload: true,
      submit_for_review: false,
      automatic_release: false,
      run_precheck_before_submit: false,
      force: true
    )
  end

  desc "Submit current version for review"
  lane :submit_for_review do
    deliver(
      api_key_path: KEY_PATH,
      app_identifier: APP_BUNDLE_ID,
      app_version: APP_VERSION,
      platform: "ios",
      skip_metadata: true,
      skip_screenshots: true,
      skip_binary_upload: true,
      submit_for_review: true,
      automatic_release: false,
      force: true,
      run_precheck_before_submit: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false,
        content_rights_contains_third_party_content: false,
        content_rights_has_rights: true
      }
    )
  end

  desc "Full ship: metadata + screenshots + submit"
  lane :ship do
    upload
    submit_for_review
  end
end

def setup_api_key
  key_id = ENV["ASC_API_KEY_ID"]
  issuer_id = ENV["ASC_API_ISSUER_ID"]
  key_b64 = ENV["ASC_API_KEY_BASE64"]
  raise "Missing ASC API env vars" unless key_id && issuer_id && key_b64

  payload = {
    "key_id"    => key_id,
    "issuer_id" => issuer_id,
    "key"       => Base64.decode64(key_b64),
    "in_house"  => false
  }
  File.write(KEY_PATH, JSON.pretty_generate(payload))
end
