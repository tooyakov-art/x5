require "base64"
require "json"

default_platform(:ios)

APP_BUNDLE_ID = "com.x5studio.app"
KEY_PATH = File.expand_path("asc_api_key.json", __dir__)

platform :ios do
  before_all do
    setup_api_key
  end

  desc "Push metadata + screenshots, do NOT submit"
  lane :upload do
    deliver(
      api_key_path: KEY_PATH,
      app_identifier: APP_BUNDLE_ID,
      skip_metadata: false,
      skip_screenshots: false,
      skip_binary_upload: true,
      submit_for_review: false,
      automatic_release: false,
      run_precheck_before_submit: false,
      overwrite_screenshots: true,
      force: true
    )
  end

  desc "Submit current version for review"
  lane :submit_for_review do
    deliver(
      api_key_path: KEY_PATH,
      app_identifier: APP_BUNDLE_ID,
      skip_metadata: true,
      skip_screenshots: true,
      skip_binary_upload: true,
      submit_for_review: true,
      automatic_release: false,
      force: true,
      run_precheck_before_submit: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false,
        content_rights_contains_third_party_content: false,
        content_rights_has_rights: true
      }
    )
  end

  desc "Full ship: metadata + screenshots + submit"
  lane :ship do
    upload
    submit_for_review
  end
end

def setup_api_key
  key_id = ENV["ASC_API_KEY_ID"]
  issuer_id = ENV["ASC_API_ISSUER_ID"]
  key_b64 = ENV["ASC_API_KEY_BASE64"]
  raise "Missing ASC API env vars" unless key_id && issuer_id && key_b64

  payload = {
    "key_id"    => key_id,
    "issuer_id" => issuer_id,
    "key"       => Base64.decode64(key_b64),
    "in_house"  => false
  }
  File.write(KEY_PATH, JSON.pretty_generate(payload))
end
